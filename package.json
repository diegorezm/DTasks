{
  "name": "dtasks",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "pnpm run build && vite preview",
    "test": "vitest run",
    "test:debug": "vitest run --reporter=verbose",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate --config=drizzle.dev.config.ts",
    "db:migrate:dev": "drizzle-kit migrate --config=drizzle.dev.config.ts",
    "db:migrate:prod": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push:dev": "drizzle-kit push --config=drizzle.dev.config.ts",
    "db:push:prod": "drizzle-kit push --config=drizzle.config.ts",
    "db:pull:dev": "drizzle-kit pull --config=drizzle.dev.config.ts",
    "db:pull:prod": "drizzle-kit pull --config=drizzle.config.ts",
    "db:studio:dev": "drizzle-kit studio --config=drizzle.dev.config.ts",
    "db:studio:prod": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.26.0",
    "@fontsource/geist": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "1.0.0-beta.22",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.75.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "1.0.0-beta.22",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.0.5",
    "wrangler": "^4.86.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "better-sqlite3"
    ]
  }
}
